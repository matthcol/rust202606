      "link": null,
      "locked": false,
      "text": "Documentation\nhttps://rust-lang.org/learn/\n\n    Book (The Rust Programming Language)\n    \n    Rust by Example\n    \n    Rustlings\n    \n    The Rust Standard Library\n    \n    The Cargo Book",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Documentation\nhttps://rust-lang.org/learn/\n\n    Book (The Rust Programming Language)\n    \n    Rust by Example\n    \n    Rustlings\n    \n    The Rust Standard Library\n    \n    The Cargo Book",
