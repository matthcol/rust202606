    {
      "id": "BSIz0FKVM4G7M5Ocod5Et",
      "type": "text",
      "x": 431.9490953829319,
      "y": 1262.6744433874096,
      "width": 659.1995239257812,
      "height": 400,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b8i",
      "roundness": null,
      "seed": 484537523,
      "version": 435,
      "versionNonce": 200204019,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1782114064936,
      "link": null,
      "locked": false,
      "text": "Caractéristiques\n\n- langage compilé : code source => code binaire\n    * performance\n            - calcul numérique\n            - noyau Linux\n    * qualité : gestion mémoire\n    * paradigmes : impératif, fonctionnel, \"objet\"\n    * portabilité\n- outils :\n    * repose sur une chaîne de build C++\n    * rustc : compilateur\n    * cargo : gestionnaire de projet (compilation, test, dépendances)\n    * IDE :\n        - VS Code + extension Rust\n        - Rust Rover (JetBrains)",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Caractéristiques\n\n- langage compilé : code source => code binaire\n    * performance\n            - calcul numérique\n            - noyau Linux\n    * qualité : gestion mémoire\n    * paradigmes : impératif, fonctionnel, \"objet\"\n    * portabilité\n- outils :\n    * repose sur une chaîne de build C++\n    * rustc : compilateur\n    * cargo : gestionnaire de projet (compilation, test, dépendances)\n    * IDE :\n        - VS Code + extension Rust\n        - Rust Rover (JetBrains)",
      "autoResize": true,
      "lineHeight": 1.25
    },
